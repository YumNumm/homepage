{
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["scripts"],
	"compilerOptions": {
		"target": "ES2022",
		"jsx": "react-jsx",
		"module": "ESNext",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["vite/client", "@cloudflare/workers-types"],

		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"strict": true,
		"sourceMap": true,
		"noEmit": true,

		"baseUrl": ".",
		"paths": {
			"$lib/*": ["./src/lib/*"]
		}
	}
}
