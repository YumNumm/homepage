{
	"name": "homepage",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "pnpm run build && wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types ./src/worker-configuration.d.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@cloudflare/workers-types": "^4.20260118.0",
		"@shikijs/colorized-brackets": "^3.21.0",
		"@shikijs/twoslash": "^3.21.0",
		"@sveltejs/adapter-cloudflare": "^7.2.5",
		"@sveltejs/kit": "^2.50.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"gray-matter": "^4.0.3",
		"hono": "^4.11.4",
		"mdsvex": "^0.12.6",
		"playwright": "^1.57.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-preset-minify": "^7.0.1",
		"rehype-slug": "^6.0.0",
		"remark-lint": "^10.0.1",
		"svelte": "^5.47.0",
		"svelte-check": "^4.3.5",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"wrangler": "^4.59.2"
	},
	"dependencies": {
		"@fontsource/google-sans-code": "^5.2.3",
		"@hono/valibot-validator": "^0.6.1",
		"@radix-ui/themes": "^3.2.1",
		"@shikijs/rehype": "^3.21.0",
		"katex": "^0.16.27",
		"rehype-katex": "^7.0.1",
		"rehype-raw": "^7.0.0",
		"rehype-stringify": "^10.0.1",
		"rehype-twoslash": "^1.1.1",
		"remark-math": "^6.0.0",
		"shiki": "^3.21.0",
		"valibot": "^1.2.0"
	}
}
